{
  "name": "@sagile/studios",
  "version": "1.0.12",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  },
  "build": {
    "appId": "com.sagile.studios",
    "productName": "Sagile Studios",
    "artifactName": "Sagile Studios.exe",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "artifactName": "Sagile Studios Setup.exe"
    },
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "dekamiles23",
      "repo": "Sagile-Studios"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  }
}
